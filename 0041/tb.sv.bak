`timescale 1ns / 1ps

module tb(
    );
    //---------------------------------------------------------
    // Input Vectors
    localparam DATA_BITS = 4;
    localparam PARITY_BITS = 3;
    localparam TOTAL_BITS = 7;
    // --------------------------------------------------------

    localparam TB_SIM_TIMEOUT = 30_000_000; //ns

reg [DATA_BITS-1:0] data_in;
wire [TOTAL_BITS-1:0] encoded_out;
wire [PARITY_BITS-1:0] parity_bits;

int ERR_COUNT = 0;

//DUT instantiation
   hamming_encoder #(
      .DATA_BITS(DATA_BITS),
      .PARITY_BITS(PARITY_BITS),
      .TOTAL_BITS(TOTAL_BITS)
   ) DUT (
      .data_in(data_in),
      .encoded_out(encoded_out),
      .parity_bits(parity_bits)
   );

// Reference function to calculate Hamming(7,4) code
function [6:0] calc_hamming_7_4(input [3:0] data);
    logic d3, d2, d1, d0;
    logic p2, p1, p0;
    begin
        {d3, d2, d1, d0} = data;

        // Calculate parity bits using even parity
        p0 = d0 ^ d1 ^ d3;  // positions 1,3,5,7
        p1 = d0 ^ d2 ^ d3;  // positions 2,3,6,7
        p2 = d1 ^ d2 ^ d3;  // positions 4,5,6,7

        // Assemble: position 7,6,5,4,3,2,1 = D3,D2,D1,P2,D0,P1,P0
        calc_hamming_7_4 = {d3, d2, d1, p2, d0, p1, p0};
    end
endfunction

// Test vectors with expected results
typedef struct {
    logic [3:0] data;
    logic [6:0] expected_encoded;
    logic [2:0] expected_parity;
    string description;
} test_vector_t;

test_vector_t test_vectors [];

// Initialize test vectors
initial begin
    test_vectors = new[16]; // Test all possible 4-bit inputs

    // Generate all test vectors
    for (int i = 0; i < 16; i++) begin
        test_vectors[i].data = i;
        test_vectors[i].expected_encoded = calc_hamming_7_4(i);
        test_vectors[i].expected_parity = test_vectors[i].expected_encoded[2:0]; // P2,P1,P0
        $sformat(test_vectors[i].description, "Data 0x%X", i);
    end
end

// Test sequence
initial begin
    // Test all possible input combinations
    $display("Testing all 4-bit input combinations");
    for (int i = 0; i < test_vectors.size(); i++) begin
        test_hamming_encoding(test_vectors[i]);
        #10;
    end

    // Verify specific cases
    verify_parity_properties();

    // Test bit position mapping
    test_bit_positions();

    check_result;
end

// Task to test Hamming encoding
task test_hamming_encoding(input test_vector_t test_vec);
    begin
        data_in = test_vec.data;
        #5; // Allow combinational delay

        $display("Testing %s: input=0x%X", test_vec.description, test_vec.data);
        $display("  Expected: encoded=0x%02X, parity=0x%X",
                 test_vec.expected_encoded, test_vec.expected_parity);
        $display("  Got:      encoded=0x%02X, parity=0x%X",
                 encoded_out, parity_bits);

        if (encoded_out !== test_vec.expected_encoded) begin
            ERR_COUNT++;
            $error("Encoded output mismatch for data 0x%X", test_vec.data);
        end

        if (parity_bits !== test_vec.expected_parity) begin
            ERR_COUNT++;
            $error("Parity bits mismatch for data 0x%X", test_vec.data);
        end

        // Verify parity bits are extracted correctly from encoded output
        if (parity_bits !== {encoded_out[3], encoded_out[1], encoded_out[0]}) begin
            ERR_COUNT++;
            $error("Parity bits don't match positions in encoded output");
        end

        // Verify data bits are preserved in correct positions
        logic [3:0] extracted_data = {encoded_out[6], encoded_out[5], encoded_out[4], encoded_out[2]};
        if (extracted_data !== test_vec.data) begin
            ERR_COUNT++;
            $error("Data bits not preserved correctly in encoded output");
        end
    end
endtask

// Task to verify parity properties
task verify_parity_properties();
    begin
        $display("Verifying parity properties");

        for (int i = 0; i < 16; i++) begin
            data_in = i;
            #5;

            // Extract bits for parity checking
            logic d3 = encoded_out[6];
            logic d2 = encoded_out[5];
            logic d1 = encoded_out[4];
            logic p2 = encoded_out[3];
            logic d0 = encoded_out[2];
            logic p1 = encoded_out[1];
            logic p0 = encoded_out[0];

            // Check parity equations (should all be 0 for even parity)
            logic parity_check_1 = p0 ^ d0 ^ d1 ^ d3; // positions 1,3,5,7
            logic parity_check_2 = p1 ^ d0 ^ d2 ^ d3; // positions 2,3,6,7
            logic parity_check_4 = p2 ^ d1 ^ d2 ^ d3; // positions 4,5,6,7

            if (parity_check_1 !== 1'b0) begin
                ERR_COUNT++;
                $error("Parity check 1 failed for data 0x%X", i);
            end

            if (parity_check_2 !== 1'b0) begin
                ERR_COUNT++;
                $error("Parity check 2 failed for data 0x%X", i);
            end

            if (parity_check_4 !== 1'b0) begin
                ERR_COUNT++;
                $error("Parity check 4 failed for data 0x%X", i);
            end
        end

        $display("  ✓ All parity properties verified");
    end
endtask

// Task to test bit position mapping
task test_bit_positions();
    begin
        $display("Testing bit position mapping");

        // Test with known pattern
        data_in = 4'b1010; // D3=1, D2=0, D1=1, D0=0
        #5;

        // Check data bit positions in encoded output
        if (encoded_out[6] !== 1'b1) begin // D3 at position 7
            ERR_COUNT++;
            $error("D3 not at correct position");
        end

        if (encoded_out[5] !== 1'b0) begin // D2 at position 6
            ERR_COUNT++;
            $error("D2 not at correct position");
        end

        if (encoded_out[4] !== 1'b1) begin // D1 at position 5
            ERR_COUNT++;
            $error("D1 not at correct position");
        end

        if (encoded_out[2] !== 1'b0) begin // D0 at position 3
            ERR_COUNT++;
            $error("D0 not at correct position");
        end

        // Verify parity bit positions
        if (parity_bits[2] !== encoded_out[3]) begin // P2 at position 4
            ERR_COUNT++;
            $error("P2 not at correct position");
        end

        if (parity_bits[1] !== encoded_out[1]) begin // P1 at position 2
            ERR_COUNT++;
            $error("P1 not at correct position");
        end

        if (parity_bits[0] !== encoded_out[0]) begin // P0 at position 1
            ERR_COUNT++;
            $error("P0 not at correct position");
        end

        $display("  ✓ Bit position mapping verified");
    end
endtask

//do not edit below
task check_result;
begin
   if(ERR_COUNT > 0) begin
      $display("Test failed with %0d errors.", ERR_COUNT);
      $display("ERROR000"); // TEST FAILED
   end else begin
      $display("PASS");
   end
   $finish;
end
endtask

string filename;

initial begin
   if ($value$plusargs("VCDFILE=%s",filename)) begin
      $dumpfile(filename);
      $dumpvars(0, DUT);
   end
end

initial begin
    #(TB_SIM_TIMEOUT)
    $display("ERROR001"); // TEST TIMEOUT
    $finish;
end

endmodule